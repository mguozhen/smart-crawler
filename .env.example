# smart-crawler 环境变量模板 —— 复制为 .env 并填入真实值
# cp .env.example .env

# PostgreSQL（服务化部署主数据库）
POSTGRES_USER=smart_crawler
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=smart_crawler
DATABASE_URL=postgresql+psycopg://smart_crawler:change-me-strong-password@postgres:5432/smart_crawler

# 应用密钥（Token 签名）
SC_SECRET=change-me-random-secret

# 管理员账号（看板登录）
# ADMIN_PASSWORD 只在首次创建账号时生效；之后在控制台改的密码不会被部署覆盖。
# 忘记密码需找回时：临时设 ADMIN_PASSWORD_FORCE_RESET=1 启动一次，再去掉。
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-admin-password
# ADMIN_PASSWORD_FORCE_RESET=1

# LLM 网关（NLP 分析 / VOC 报告）—— flatkey OpenAI 兼容代理
OPENAI_API_KEY=
LLM_BASE_URL=https://router.flatkey.ai/v1
LLM_MODEL=gpt-5-mini

# Amazon VOC 工具 —— apps.voc.ai/openapi 免费注册
VOC_API_KEY=

# Cloudflare Tunnel（smartcrawler.io 接入）
TUNNEL_TOKEN=

# 定时采集 worker 并发 + 内存安全闸
# WORKER_THREADS：进程内 worker 线程数(每线程跑一个真浏览器)。默认 1。
#   调高可提速,但每个浏览器吃 300-800MB,小内存机器配合下面的内存闸使用。
# WORKER_THREADS=1
#
# 内存自适应并发闸 —— 主机已用内存 ≥ MEM_GATE_THRESHOLD% 时,worker 暂停领新 job
# (不起新浏览器),内存回落自动恢复。读 /proc/meminfo,读不到则放行(fail-open)。
# 设 0 或 100 关闸。
MEM_GATE_THRESHOLD=80
# MEM_GATE_CHECK_INTERVAL=2     # 闸内查内存间隔(秒)
# MEM_GATE_MAX_WAIT=300         # 单轮最多等待(秒),超时回循环重判
